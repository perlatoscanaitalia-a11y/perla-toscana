---
import { getWhatsAppLinks, siteConfig } from '../data/siteConfig';
import WhatsAppIcon from './WhatsAppIcon.astro';

interface Props {
  lang: 'it' | 'en';
}

const { lang } = Astro.props;
const whatsappLinks = getWhatsAppLinks(lang);

function isRealUrl(value: string) {
  return /^https?:\/\/.+/i.test(value);
}

const optionalSocials = [
  { label: 'Instagram', href: siteConfig.social.instagramUrl },
  { label: 'Facebook', href: siteConfig.social.facebookUrl },
  { label: 'Pinterest', href: siteConfig.social.pinterestUrl },
  { label: 'TikTok', href: siteConfig.social.tiktokUrl }
].filter((item) => isRealUrl(item.href));

---
<div class="social-links" aria-label={lang === 'it' ? 'Seguici' : 'Follow us'}>
  <h3>{lang === 'it' ? 'Seguici' : 'Follow us'}</h3>
  <div class="social-links__row">
    {optionalSocials.map((item) => (
      <a class="social-links__item" href={item.href} target="_blank" rel="noopener noreferrer" data-track={`social_${item.label.toLowerCase()}_click`} aria-label={`${item.label} Perla Toscana`}>
        <span>{item.label}</span>
      </a>
    ))}
    <a class="social-links__item social-links__item--whatsapp social-links__item--whatsapp-desktop" href={whatsappLinks.desktop} target="_blank" rel="noopener noreferrer" data-track="social_whatsapp_click" aria-label="WhatsApp Perla Toscana">
      <WhatsAppIcon />
      <span>WhatsApp</span>
    </a>
    <a class="social-links__item social-links__item--whatsapp social-links__item--whatsapp-mobile" href={whatsappLinks.mobile} target="_blank" rel="noopener noreferrer" data-track="social_whatsapp_click" aria-label="WhatsApp Perla Toscana">
      <WhatsAppIcon />
      <span>WhatsApp</span>
    </a>
  </div>
</div>

<style>
  .social-links {
    display: grid;
    gap: 12px;
  }

  .social-links h3 {
    margin: 0;
  }

  .social-links__row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .social-links__item {
    display: inline-flex;
    min-height: 38px;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255, 253, 248, 0.22);
    border-radius: 999px;
    color: rgba(255, 253, 248, 0.84);
    font-size: 0.94rem;
    font-weight: 700;
    line-height: 1;
    padding: 9px 13px;
    text-decoration: none;
    transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
  }

  .social-links__item:hover {
    border-color: rgba(255, 253, 248, 0.62);
    background: rgba(255, 253, 248, 0.08);
    color: var(--color-warm-white);
  }

  .social-links__item--whatsapp-mobile {
    display: none;
  }

  @media (max-width: 820px) {
    .social-links__item--whatsapp-desktop {
      display: none;
    }

    .social-links__item--whatsapp-mobile {
      display: inline-flex;
    }
  }
</style>
