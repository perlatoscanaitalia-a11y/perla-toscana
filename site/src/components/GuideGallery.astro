---
interface Image { src: string; alt: string; }
interface Props { images: Image[]; title?: string; }
const { images, title = 'Immagini della guida' } = Astro.props;
---
<section class="guide-gallery" aria-labelledby="gallery-title"><h2 id="gallery-title">{title}</h2><div class="guide-gallery__track">{images.map(image => <figure><img src={image.src} alt={image.alt} width="900" height="600" loading="lazy" /></figure>)}</div></section>
<style>.guide-gallery{display:grid;gap:18px}.guide-gallery__track{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}.guide-gallery figure{margin:0;overflow:hidden;border-radius:var(--radius);background:var(--color-sand)}.guide-gallery img{width:100%;height:100%;aspect-ratio:4/3;object-fit:cover}@media(max-width:650px){.guide-gallery__track{display:flex;gap:12px;overflow-x:auto;scroll-snap-type:x mandatory;padding-bottom:8px}.guide-gallery figure{flex:0 0 86%;scroll-snap-align:start}.guide-gallery__track::-webkit-scrollbar{height:6px}.guide-gallery__track::-webkit-scrollbar-thumb{background:var(--color-gold);border-radius:999px}}</style>
