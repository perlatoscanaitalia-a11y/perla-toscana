---
interface Props {
  lang: 'it' | 'en';
}

const { lang } = Astro.props;
const content = {
  it: {
    text: 'Usiamo cookie tecnici e, solo con il tuo consenso, Google Analytics 4 per capire come viene utilizzato il sito. Non usiamo cookie pubblicitari o di profilazione.',
    accept: 'Accetta analytics',
    reject: 'Rifiuta',
    policy: 'Cookie Policy',
    policyHref: '/it/cookie-policy/'
  },
  en: {
    text: 'We use technical cookies and, only with your consent, Google Analytics 4 to understand how the site is used. We do not use advertising or profiling cookies.',
    accept: 'Accept analytics',
    reject: 'Reject',
    policy: 'Cookie Policy',
    policyHref: '/en/cookie-policy/'
  }
};
---
<aside class="cookie-banner" data-cookie-banner hidden>
  <div class="cookie-banner__inner">
    <p>{content[lang].text}</p>
    <div class="cookie-banner__actions">
      <button class="button button--primary" type="button" data-cookie-accept>
        {content[lang].accept}
      </button>
      <button class="button button--secondary" type="button" data-cookie-reject>
        {content[lang].reject}
      </button>
      <a class="button button--secondary cookie-banner__policy" href={content[lang].policyHref}>
        {content[lang].policy}
      </a>
    </div>
  </div>
</aside>

<script is:inline>
  const cookieBanner = document.querySelector('[data-cookie-banner]');
  const cookieAccept = document.querySelector('[data-cookie-accept]');
  const cookieReject = document.querySelector('[data-cookie-reject]');
  const cookieSettings = document.querySelectorAll('[data-cookie-settings]');
  const storageKey = 'perlaToscanaAnalyticsConsent';

  const saveChoice = (choice) => {
    try { localStorage.setItem(storageKey, choice); } catch { /* Keep session-only choice. */ }
    window.perlaToscanaAnalytics?.setConsent(choice === 'granted');
    cookieBanner?.setAttribute('hidden', '');
  };

  try {
    if (cookieBanner && !['granted', 'denied'].includes(localStorage.getItem(storageKey))) {
      cookieBanner.removeAttribute('hidden');
    }
  } catch {
    cookieBanner?.removeAttribute('hidden');
  }

  cookieAccept?.addEventListener('click', () => saveChoice('granted'));
  cookieReject?.addEventListener('click', () => saveChoice('denied'));
  cookieSettings.forEach((button) => button.addEventListener('click', () => cookieBanner?.removeAttribute('hidden')));
</script>

<style>
  .cookie-banner {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 30;
    padding: 16px;
  }

  .cookie-banner[hidden] {
    display: none;
  }

  .cookie-banner__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: center;
    width: min(1040px, 100%);
    margin: 0 auto;
    border: 1px solid rgba(104, 88, 61, 0.26);
    border-radius: var(--radius);
    background: var(--color-warm-white);
    box-shadow: 0 18px 48px rgba(47, 42, 36, 0.18);
    color: var(--color-espresso);
    padding: 18px;
  }

  .cookie-banner__inner p {
    font-size: 0.95rem;
  }

  .cookie-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .cookie-banner__actions .button {
    min-height: 42px;
    padding: 10px 16px;
    white-space: nowrap;
  }

  .cookie-banner__policy {
    background: var(--color-warm-white);
  }

  @media (max-width: 760px) {
    .cookie-banner {
      padding: 12px;
    }

    .cookie-banner__inner {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 16px;
    }

    .cookie-banner__actions {
      justify-content: stretch;
    }

    .cookie-banner__actions .button {
      width: 100%;
    }
  }
</style>
