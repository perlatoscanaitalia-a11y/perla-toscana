---
interface Props {
  lang: 'it' | 'en';
}

const { lang } = Astro.props;
const content = {
  it: {
    text: 'Questo sito utilizza solo cookie tecnici necessari al funzionamento. Non utilizziamo cookie di profilazione o marketing. Puoi leggere la Cookie Policy per maggiori informazioni.',
    dismiss: 'Ho capito',
    policy: 'Cookie Policy',
    policyHref: '/it/cookie-policy/'
  },
  en: {
    text: 'This website uses only technical cookies necessary for it to work. We do not use profiling or marketing cookies. You can read the Cookie Policy for more information.',
    dismiss: 'Got it',
    policy: 'Cookie Policy',
    policyHref: '/en/cookie-policy/'
  }
};
---
<aside class="cookie-banner" data-cookie-banner hidden>
  <div class="cookie-banner__inner">
    <p>{content[lang].text}</p>
    <div class="cookie-banner__actions">
      <button class="button button--primary" type="button" data-cookie-dismiss>
        {content[lang].dismiss}
      </button>
      <a class="button button--secondary cookie-banner__policy" href={content[lang].policyHref}>
        {content[lang].policy}
      </a>
    </div>
  </div>
</aside>

<script is:inline>
  const cookieBanner = document.querySelector('[data-cookie-banner]');
  const cookieDismiss = document.querySelector('[data-cookie-dismiss]');
  const storageKey = 'perlaToscanaCookieInfoSeen';

  try {
    if (cookieBanner && localStorage.getItem(storageKey) !== 'true') {
      cookieBanner.removeAttribute('hidden');
    }

    cookieDismiss?.addEventListener('click', () => {
      localStorage.setItem(storageKey, 'true');
      cookieBanner?.setAttribute('hidden', '');
    });
  } catch {
    cookieBanner?.removeAttribute('hidden');
    cookieDismiss?.addEventListener('click', () => {
      cookieBanner?.setAttribute('hidden', '');
    });
  }
</script>

<style>
  .cookie-banner {
    position: fixed;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 30;
    padding: 16px;
  }

  .cookie-banner[hidden] {
    display: none;
  }

  .cookie-banner__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 18px;
    align-items: center;
    width: min(1040px, 100%);
    margin: 0 auto;
    border: 1px solid rgba(104, 88, 61, 0.26);
    border-radius: var(--radius);
    background: var(--color-warm-white);
    box-shadow: 0 18px 48px rgba(47, 42, 36, 0.18);
    color: var(--color-espresso);
    padding: 18px;
  }

  .cookie-banner__inner p {
    font-size: 0.95rem;
  }

  .cookie-banner__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: flex-end;
  }

  .cookie-banner__actions .button {
    min-height: 42px;
    padding: 10px 16px;
    white-space: nowrap;
  }

  .cookie-banner__policy {
    background: var(--color-warm-white);
  }

  @media (max-width: 760px) {
    .cookie-banner {
      padding: 12px;
    }

    .cookie-banner__inner {
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 16px;
    }

    .cookie-banner__actions {
      justify-content: stretch;
    }

    .cookie-banner__actions .button {
      width: 100%;
    }
  }
</style>
