---
import { siteConfig } from '../data/siteConfig';

interface Props {
  title: string;
  description: string;
  path: string;
  lang: 'it' | 'en';
  alternatePath?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
  ogType?: 'website' | 'article';
}

const { title, description, path, lang, alternatePath, schema, noindex = false, ogType = 'website' } = Astro.props;
const canonical = new URL(path, siteConfig.siteUrl).toString();
const alternateLang = lang === 'it' ? 'en' : 'it';
const alternateUrl = alternatePath ? new URL(alternatePath, siteConfig.siteUrl).toString() : undefined;
const socialImage = new URL('/images/perla-toscana/perla-toscana-hero-camera-principale-9.jpg', siteConfig.siteUrl).toString();
---
<title>{title}</title>
<link rel="icon" href="/favicon.svg" type="image/svg+xml" sizes="any" />
<link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
<meta name="description" content={description} />
<meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
<link rel="canonical" href={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonical} />
<meta property="og:site_name" content={siteConfig.name} />
<meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
<meta property="og:locale:alternate" content={lang === 'it' ? 'en_US' : 'it_IT'} />
<meta property="og:image" content={socialImage} />
<meta property="og:image:alt" content={lang === 'it' ? 'Camera matrimoniale di Perla Toscana a Figline Valdarno' : 'Double bedroom at Perla Toscana in Figline Valdarno'} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={socialImage} />
<link rel="alternate" hreflang={lang} href={canonical} />
{alternateUrl && <link rel="alternate" hreflang={alternateLang} href={alternateUrl} />}
{alternateUrl && <link rel="alternate" hreflang="x-default" href={lang === 'it' ? canonical : alternateUrl} />}
{schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
