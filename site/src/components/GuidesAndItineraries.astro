---
import type { Lang } from '../data/pages';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const destinations = lang === 'it' ? ['Firenze', 'Chianti', 'The Mall Firenze', 'Siena', 'San Gimignano', 'Val d’Orcia', 'Valdarno e natura'] : ['Florence', 'Chianti', 'The Mall Firenze', 'Siena', 'San Gimignano', 'Val d’Orcia', 'Valdarno and nature'];
---
<section class="section section--sand" aria-labelledby={`map-title-${lang}`}>
  <div class="container map-stack">
    <div class="map-heading"><p class="eyebrow">{lang === 'it' ? 'Esplora la Toscana' : 'Explore Tuscany'}</p><h2 id={`map-title-${lang}`}>{lang === 'it' ? 'Destinazioni da Perla Toscana' : 'Destinations from Perla Toscana'}</h2><p>{lang === 'it' ? 'Una base nel Valdarno per raggiungere città d’arte, borghi, shopping e paesaggi toscani con itinerari semplici da organizzare.' : 'A Valdarno base for reaching art cities, villages, shopping and Tuscan landscapes with easy-to-plan itineraries.'}</p></div>
    <figure class="tuscany-map"><img src="/images/generated/mappa-illustrata-toscana-perla.webp" alt={lang === 'it' ? 'Mappa illustrata della Toscana con città, borghi e paesaggi raggiungibili da Perla Toscana' : 'Illustrated map of Tuscany with cities, villages and landscapes accessible from Perla Toscana'} width="1600" height="800" loading="lazy"/><figcaption>{lang === 'it' ? 'Mappa illustrativa: distanze e tempi effettivi dipendono dal percorso e dal traffico.' : 'Illustrative map: actual distances and travel times depend on route and traffic.'}</figcaption></figure>
    <div class="destination-list" aria-label={lang === 'it' ? 'Destinazioni principali' : 'Main destinations'}>{destinations.map((destination) => <span>{destination}</span>)}</div>
    <a class="button button--primary all-guides" href={lang === 'it' ? '/guide/' : '/en/guides/'}>{lang === 'it' ? 'Esplora tutte le guide' : 'Explore all guides'}</a>
  </div>
</section>
<style>
.map-stack,.map-heading{display:grid;gap:18px}.map-heading{max-width:820px}.tuscany-map{overflow:hidden;border:1px solid var(--color-border);border-radius:var(--radius);background:var(--color-warm-white);box-shadow:var(--shadow-soft)}.tuscany-map img{display:block;width:100%;aspect-ratio:1.95/1;object-fit:cover}.tuscany-map figcaption{color:rgba(47,42,36,.68);font-size:.84rem;padding:10px 14px}.destination-list{display:flex;flex-wrap:wrap;gap:9px}.destination-list span{border:1px solid rgba(102,114,77,.22);border-radius:999px;background:rgba(102,114,77,.08);color:var(--color-olive);font-size:.86rem;font-weight:800;padding:7px 11px}.all-guides{width:fit-content}@media(max-width:620px){.tuscany-map img{aspect-ratio:4/3}.all-guides{width:100%;text-align:center}}
</style>
