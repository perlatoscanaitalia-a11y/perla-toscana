---
import type { Lang } from '../data/pages';
interface Props { lang: Lang; }
const { lang } = Astro.props;
const destinations = lang === 'it' ? [
  { name: 'Firenze', x: 47, y: 34 },
  { name: 'Chianti', x: 40, y: 49 },
  { name: 'The Mall Firenze', x: 58, y: 43 },
  { name: 'Siena', x: 50, y: 68 },
  { name: 'San Gimignano', x: 36, y: 46 },
  { name: 'Val d’Orcia', x: 63, y: 72 },
  { name: 'Valdarno e natura', x: 64, y: 54 }
] : [
  { name: 'Florence', x: 47, y: 34 },
  { name: 'Chianti', x: 40, y: 49 },
  { name: 'The Mall Firenze', x: 58, y: 43 },
  { name: 'Siena', x: 50, y: 68 },
  { name: 'San Gimignano', x: 36, y: 46 },
  { name: 'Val d’Orcia', x: 63, y: 72 },
  { name: 'Valdarno and nature', x: 64, y: 54 }
];
---
<section class="section section--sand" aria-labelledby={`map-title-${lang}`}>
  <div class="container map-stack">
    <div class="map-heading"><p class="eyebrow">{lang === 'it' ? 'Esplora la Toscana' : 'Explore Tuscany'}</p><h2 id={`map-title-${lang}`}>{lang === 'it' ? 'Destinazioni da Perla Toscana' : 'Destinations from Perla Toscana'}</h2><p>{lang === 'it' ? 'Una base nel Valdarno per raggiungere città d’arte, borghi, shopping e paesaggi toscani con itinerari semplici da organizzare.' : 'A Valdarno base for reaching art cities, villages, shopping and Tuscan landscapes with easy-to-plan itineraries.'}</p></div>
    <figure class="tuscany-map">
      <div class="map-canvas">
        <img src="/images/generated/mappa-illustrata-toscana-perla-v2.webp" alt={lang === 'it' ? 'Mappa illustrata della Toscana con le destinazioni raggiungibili da Perla Toscana' : 'Illustrated map of Tuscany with destinations accessible from Perla Toscana'} width="1600" height="800" loading="lazy"/>
        {destinations.map((destination, index) => <span class="map-pin" style={`--x:${destination.x}%;--y:${destination.y}%`} aria-hidden="true"><span>{index + 1}</span></span>)}
        <span class="home-marker" aria-hidden="true"><span class="home-marker__star">★</span><span>Perla Toscana</span></span>
      </div>
      <figcaption>{lang === 'it' ? 'Mappa illustrativa: distanze e tempi effettivi dipendono dal percorso e dal traffico.' : 'Illustrative map: actual distances and travel times depend on route and traffic.'}</figcaption>
    </figure>
    <div class="map-key" aria-labelledby={`legend-title-${lang}`}><h3 id={`legend-title-${lang}`}>{lang === 'it' ? 'Legenda delle destinazioni' : 'Destination key'}</h3><ol>{destinations.map((destination) => <li>{destination.name}</li>)}</ol><p class="home-key"><span aria-hidden="true">★</span><strong>Perla Toscana</strong> — {lang === 'it' ? 'la tua base nel Valdarno' : 'your base in Valdarno'}</p></div>
    <a class="button button--primary all-guides" href={lang === 'it' ? '/guide/' : '/en/guides/'}>{lang === 'it' ? 'Esplora tutte le guide' : 'Explore all guides'}</a>
  </div>
</section>
<style>
.map-stack,.map-heading,.map-key{display:grid;gap:18px}.map-heading{max-width:820px}.tuscany-map{overflow:hidden;border:1px solid var(--color-border);border-radius:var(--radius);background:var(--color-warm-white);box-shadow:var(--shadow-soft)}.map-canvas{position:relative}.map-canvas img{display:block;width:100%;height:auto}.map-pin{position:absolute;left:var(--x);top:var(--y);display:grid;width:34px;height:34px;place-items:center;border:2px solid var(--color-warm-white);border-radius:50% 50% 50% 0;background:var(--color-terracotta);box-shadow:0 3px 9px rgba(47,42,36,.3);color:var(--color-warm-white);font-size:.9rem;font-weight:900;line-height:1;transform:translate(-50%,-100%) rotate(-45deg)}.map-pin>span{font-variant-numeric:tabular-nums;transform:rotate(45deg)}.home-marker{position:absolute;left:55%;top:52%;display:flex;align-items:center;gap:6px;border:2px solid var(--color-warm-white);border-radius:999px;background:var(--color-olive);box-shadow:0 3px 10px rgba(47,42,36,.3);color:var(--color-warm-white);font-size:.78rem;font-weight:900;padding:5px 9px;transform:translate(-50%,-50%);white-space:nowrap}.home-marker__star{color:#ffe4a8;font-size:1.1rem}.tuscany-map figcaption{color:rgba(47,42,36,.68);font-size:.84rem;padding:10px 14px}.map-key{border:1px solid var(--color-border);border-radius:var(--radius);background:rgba(255,255,255,.5);padding:20px}.map-key h3{font-size:1.35rem}.map-key ol{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px 28px;margin:0;padding-left:28px}.map-key li{padding-left:5px;font-weight:700}.map-key li::marker{color:var(--color-terracotta);font-weight:900}.home-key{display:flex;align-items:center;gap:8px;border-top:1px solid var(--color-border);padding-top:14px}.home-key>span{color:var(--color-olive);font-size:1.25rem}.all-guides{width:fit-content}@media(max-width:620px){.map-pin{width:28px;height:28px;font-size:.78rem}.home-marker{left:56%;font-size:.68rem;padding:4px 7px}.home-marker__star{font-size:.95rem}.map-key{padding:17px}.map-key ol{grid-template-columns:1fr;gap:9px}.home-key{align-items:flex-start;flex-wrap:wrap}.all-guides{width:100%;text-align:center}}
</style>
