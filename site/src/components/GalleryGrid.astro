---
import { gallerySections } from '../data/galleryImages';
import type { Lang } from '../data/pages';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---
<div class="gallery-sections">
  {gallerySections.map((section) => (
    <section class="gallery-section" aria-labelledby={`gallery-${section.id}`}>
      <header class="gallery-section__header">
        <h2 id={`gallery-${section.id}`}>{section.title[lang]}</h2>
        <p>{section.description[lang]}</p>
      </header>
      <div class="gallery-grid">
        {section.images.map((item) => (
          <figure class="gallery-item">
            <img src={item.src} alt={item.alt[lang]} width="1600" height="1067" loading="lazy" decoding="async" />
            <figcaption>{item.caption[lang]}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  ))}
</div>

<style>
  .gallery-sections,
  .gallery-section {
    display: grid;
  }

  .gallery-sections {
    gap: clamp(44px, 7vw, 76px);
  }

  .gallery-section {
    gap: 22px;
    scroll-margin-top: 96px;
  }

  .gallery-section__header {
    display: grid;
    max-width: 760px;
    gap: 10px;
  }

  .gallery-section__header h2 {
    color: var(--color-espresso);
  }

  .gallery-section__header p {
    color: rgba(47, 42, 36, 0.8);
    line-height: 1.65;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
  }

  .gallery-item {
    display: grid;
    grid-template-rows: auto 1fr;
    margin: 0;
    overflow: hidden;
    border-radius: var(--radius);
    background: var(--color-warm-white);
    box-shadow: var(--shadow-soft);
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: var(--color-sand);
    object-fit: contain;
    transition: transform 0.24s ease;
  }

  .gallery-item figcaption {
    padding: 13px 15px 15px;
    color: rgba(47, 42, 36, 0.78);
    font-size: 0.94rem;
    font-weight: 600;
    line-height: 1.45;
  }

  @media (hover: hover) {
    .gallery-item:hover img {
      transform: scale(1.018);
    }
  }

  @media (max-width: 920px) {
    .gallery-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 620px) {
    .gallery-sections {
      gap: 46px;
    }

    .gallery-section {
      gap: 16px;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    .gallery-section__header p {
      font-size: 0.98rem;
    }
  }
</style>
