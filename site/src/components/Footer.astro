---
import { footerLinks } from '../data/navigation';
import { getWhatsAppLinks, siteConfig } from '../data/siteConfig';
import WhatsAppIcon from './WhatsAppIcon.astro';
import SocialLinks from './SocialLinks.astro';

interface Props {
  lang: 'it' | 'en';
  showSalesCtas?: boolean;
}

const { lang, showSalesCtas = true } = Astro.props;
const whatsappLinks = getWhatsAppLinks(lang);
---
<footer class="site-footer">
  <div class="container footer-grid">
    <div>
      <h2>Perla Toscana</h2>
      <p>{lang === 'it' ? 'Appartamento vicino Firenze con giardino e parcheggio privato fino a 3 auto.' : 'Apartment near Florence with garden and private parking for up to 3 cars.'}</p>
      <p>{siteConfig.placeholders.address}</p>
      <p>CIN: {siteConfig.placeholders.cin}</p>
      <p>CIR: {siteConfig.placeholders.cir}</p>
    </div>
    {showSalesCtas && (
    <div>
      <h3>{lang === 'it' ? 'Contatti' : 'Contact'}</h3>
      <a class="phone-nowrap" href={siteConfig.placeholders.phoneHref} data-track="phone_click">{siteConfig.placeholders.phone}</a>
      <a class="phone-nowrap" href={siteConfig.placeholders.secondaryPhoneHref} data-track="secondary_phone_click">{siteConfig.placeholders.secondaryPhone}</a>
        <a class="footer-whatsapp footer-whatsapp--desktop" href={whatsappLinks.desktop} target="_blank" rel="noopener noreferrer" data-track="whatsapp_click"><WhatsAppIcon /> WhatsApp</a>
        <a class="footer-whatsapp footer-whatsapp--mobile" href={whatsappLinks.mobile} target="_blank" rel="noopener noreferrer" data-track="whatsapp_click"><WhatsAppIcon /> WhatsApp</a>
        <a href={siteConfig.placeholders.avaiBookUrl} target="_blank" rel="noopener noreferrer" data-track="availability_click">{lang === 'it' ? 'Verifica disponibilità' : 'Check availability'}</a>
      </div>
    )}
    <div>
      <h3>{lang === 'it' ? 'Informazioni' : 'Information'}</h3>
      {footerLinks[lang].map((item) => <a href={item.href}>{item.label}</a>)}
      <a href={lang === 'it' ? '/en/' : '/it/'}>{lang === 'it' ? 'English' : 'Italiano'}</a>
      <div class="footer-social">
        <SocialLinks lang={lang} />
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-espresso);
    color: var(--color-warm-white);
    padding: 56px 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr;
    gap: 32px;
  }

  .site-footer h2,
  .site-footer h3 {
    margin-bottom: 14px;
  }

  .site-footer p,
  .site-footer a {
    display: block;
    margin-bottom: 8px;
    color: rgba(255, 253, 248, 0.84);
    text-decoration: none;
  }

  .site-footer a.phone-nowrap {
    display: block;
    width: fit-content;
    max-width: 100%;
  }

  .site-footer .footer-whatsapp {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #7ED0A0;
  }

  .site-footer .footer-whatsapp--mobile {
    display: none;
  }

  .site-footer .footer-whatsapp:hover {
    color: var(--color-warm-white);
  }

  .footer-social {
    margin-top: 22px;
  }

  @media (max-width: 820px) {
    .site-footer {
      padding: 44px 0;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    .site-footer p,
    .site-footer a {
      line-height: 1.45;
    }

    .site-footer .footer-whatsapp--desktop {
      display: none;
    }

    .site-footer .footer-whatsapp--mobile {
      display: inline-flex;
    }
  }
</style>
