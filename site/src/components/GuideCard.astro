---
interface Props { href:string; image:string; alt:string; category:string; title:string; description:string; distance:string; travelTime:string; badges:string[]; date?:string; readingTime?:string; }
const { href,image,alt,category,title,description,distance,travelTime,badges,date,readingTime }=Astro.props;
---
<article class="guide-card card"><a class="guide-card__image" href={href}><img src={image} alt={alt} width="1200" height="800" loading="lazy"/></a><div class="guide-card__body"><p class="guide-card__category">{category}</p>{(date||readingTime)&&<p class="guide-card__meta">{date}{date&&readingTime?' · ':''}{readingTime}</p>}<h2><a href={href}>{title}</a></h2><p>{description}</p><div class="guide-card__journey"><span>📍 {distance}</span><span>🕒 {travelTime}</span></div><ul>{badges.map(badge=><li>{badge}</li>)}</ul><a class="guide-card__action" href={href}>Leggi la guida <span aria-hidden="true">→</span></a></div></article>
<style>.guide-card{max-width:760px;padding:0;overflow:hidden;box-shadow:var(--shadow-soft)}.guide-card__image{display:block}.guide-card__image img{width:100%;aspect-ratio:16/9;object-fit:cover}.guide-card__body{display:grid;gap:13px;padding:26px}.guide-card__category,.guide-card__meta{color:var(--color-olive);font-size:.8rem;font-weight:800;text-transform:uppercase}.guide-card__meta{text-transform:none;font-weight:600}.guide-card h2{font-size:clamp(1.7rem,4vw,2.35rem)}.guide-card h2 a,.guide-card__action{text-decoration:none}.guide-card__journey{display:flex;flex-wrap:wrap;gap:8px 20px;color:rgba(51,37,29,.76);font-size:.9rem;font-weight:700}.guide-card ul{display:flex;flex-wrap:wrap;gap:7px;margin:0;padding:0;list-style:none}.guide-card li{border:1px solid rgba(102,114,77,.2);border-radius:999px;background:rgba(102,114,77,.08);color:var(--color-olive);font-size:.78rem;font-weight:800;padding:5px 10px}.guide-card__action{width:fit-content;color:var(--color-terracotta);font-weight:800;margin-top:4px}@media(max-width:600px){.guide-card__body{padding:20px}}</style>
