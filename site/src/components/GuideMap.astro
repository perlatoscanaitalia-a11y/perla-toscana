---
interface Props { title?: string; description?: string; embedUrl?: string; staticImage?: string; imageAlt?: string; directionsUrl?: string; }
const { title='Come arrivare', description, embedUrl, staticImage, imageAlt='Mappa della destinazione', directionsUrl }=Astro.props;
---
<section class="guide-map"><div><h2>{title}</h2>{description&&<p>{description}</p>}</div><div class="guide-map__frame">{embedUrl?<iframe src={embedUrl} title={`Mappa: ${title}`} loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>:staticImage?<img src={staticImage} alt={imageAlt} width="1200" height="600" loading="lazy"/>:<div class="guide-map__empty">Mappa disponibile a breve</div>}</div>{directionsUrl&&<a class="button button--secondary" href={directionsUrl} target="_blank" rel="noopener noreferrer">Apri le indicazioni</a>}</section>
<style>.guide-map{display:grid;gap:18px}.guide-map>div:first-child{display:grid;gap:10px}.guide-map__frame{overflow:hidden;border:1px solid var(--color-border);border-radius:var(--radius);background:var(--color-sand)}.guide-map iframe,.guide-map img,.guide-map__empty{display:block;width:100%;height:380px;border:0;object-fit:cover}.guide-map__empty{display:grid;place-items:center;color:var(--color-olive)}.guide-map>.button{width:fit-content}@media(max-width:650px){.guide-map iframe,.guide-map img,.guide-map__empty{height:300px}.guide-map>.button{width:100%}}</style>
