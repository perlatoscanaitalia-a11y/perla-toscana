---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SeoHead from '../components/SeoHead.astro';

interface Props {
  lang: 'it' | 'en';
  title: string;
  description: string;
  path: string;
  alternatePath?: string;
  schema?: Record<string, unknown> | Record<string, unknown>[];
}

const { lang, title, description, path, alternatePath, schema } = Astro.props;
const hideSalesCtas = [
  '/it/privacy-policy/',
  '/it/cookie-policy/',
  '/it/termini-condizioni/',
  '/it/informazioni-legali/',
  '/en/privacy-policy/',
  '/en/cookie-policy/',
  '/en/terms-and-conditions/',
  '/en/legal-information/'
].includes(path);
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="p:domain_verify" content="e4e3d229e7f5fa2a0f49b2fdd216c21c" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <SeoHead title={title} description={description} path={path} lang={lang} alternatePath={alternatePath} schema={schema} />
  </head>
  <body>
    <Header lang={lang} alternateHref={alternatePath} showSalesCtas={!hideSalesCtas} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} showSalesCtas={!hideSalesCtas} />
    <CookieBanner lang={lang} />
  </body>
</html>
