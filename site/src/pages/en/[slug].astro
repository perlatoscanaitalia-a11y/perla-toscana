---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageContent from '../../components/PageContent.astro';
import { pages } from '../../data/pages';
import { lodgingSchema, faqSchema } from '../../data/schema';

export function getStaticPaths() {
  return pages.en.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const allFaqs = [...(page.propertyFaqs ?? []), ...(page.faqs ?? [])];
const schema = [lodgingSchema('en', page.path), faqSchema(allFaqs)].filter(Boolean);
---
<BaseLayout lang="en" title={page.title} description={page.description} path={page.path} alternatePath={page.alternatePath} schema={schema}>
  <PageContent lang="en" page={page} />
</BaseLayout>
