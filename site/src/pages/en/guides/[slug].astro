---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PageContent from '../../../components/PageContent.astro';
import { guides } from '../../../data/guides';
import { faqSchema, guideSchema, lodgingSchema } from '../../../data/schema';

export function getStaticPaths() {
  return guides.en.filter(page => page.path.includes('/guides/') && page.slug !== 'figline-valdarno').map(page => ({ params: { slug: page.slug }, props: { page } }));
}
const { page } = Astro.props;
const schema = [lodgingSchema('en', page.path), ...guideSchema('en', page), faqSchema(page.faqs)].filter(Boolean);
---
<BaseLayout lang="en" title={page.title} description={page.description} path={page.path} alternatePath={page.alternatePath} schema={schema}>
  <PageContent lang="en" page={page} />
</BaseLayout>
