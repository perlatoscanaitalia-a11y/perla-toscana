---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageContent from '../../components/PageContent.astro';
import { pages } from '../../data/pages';
import { lodgingSchema, faqSchema } from '../../data/schema';

export function getStaticPaths() {
  return pages.it.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));
}

const { page } = Astro.props;
const schema = [lodgingSchema('it', page.path), faqSchema(page.faqs)].filter(Boolean);
---
<BaseLayout lang="it" title={page.title} description={page.description} path={page.path} alternatePath={page.alternatePath} schema={schema}>
  <PageContent lang="it" page={page} />
</BaseLayout>
